# Public (client-safe) env vars
# Set these in your deployment environment. Keep values blank in committed files.

PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SCRIPT_SRC=

# Private (server-only) env vars
# NEVER commit these values. Add them to your deployment environment only.

# RESEND_API_KEY=re_btSSN31D_PELm2mj55AzgHsQEZrRExyxW

# Buttondown API (same credentials for all environments)
BUTTONDOWN_API_KEY=<your-buttondown-api-key>
BUTTONDOWN_WEBHOOK_SIGNING_KEY=<your-buttondown-webhook-signing-key>

# (Optional) Test email identifier for filtering later
TEST_SUBSCRIBER_TAG=qa-subscriber
